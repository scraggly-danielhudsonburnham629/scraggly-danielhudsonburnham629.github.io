# -------------------------------------------------------------
# Deploy hygiene — nothing under `dev/` should ever ship to Pages.
# dev/ holds the property-based test harness, Playwright specs,
# and their node_modules. Not needed at runtime, and exposes
# internal test scaffolding if published.
# -------------------------------------------------------------
dev/

# -------------------------------------------------------------
# Node — node_modules is huge and reproducible from package-lock.
# The lockfile itself IS committed for deterministic esbuild version.
# -------------------------------------------------------------
node_modules/
yarn.lock
pnpm-lock.yaml
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------------------------------------------
# Editor / OS junk
# -------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# -------------------------------------------------------------
# Build outputs — committed to the repo since Pages serves the
# `build/` folder directly. `deploy.ps1` rebuilds before every push
# so the committed bundle always matches the source.
# Other tooling scratch dirs stay excluded.
# -------------------------------------------------------------
.cache/
